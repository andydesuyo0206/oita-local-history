---
// 郷土史イラストSVG：name で切り替える自作アイコン集
// torii=鳥居 / ship=南蛮船 / sekibutsu=磨崖仏 / castle=岡城の石垣と月 / yukemuri=湯けむり
// cross=キリシタン / school=私塾 / stadium=スタジアム / taimatsu=修正鬼会の松明
// mizushiro=中津城（水城） / saka=杵築の石畳坂 / yamajiro=佐伯城（山城と海）
interface Props {
  name:
    | 'torii'
    | 'ship'
    | 'sekibutsu'
    | 'castle'
    | 'yukemuri'
    | 'cross'
    | 'school'
    | 'stadium'
    | 'taimatsu'
    | 'mizushiro'
    | 'saka'
    | 'yamajiro'
    | 'yufudake';
  size?: number;
}
const { name, size = 96 } = Astro.props;
---

{name === 'torii' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="鳥居のイラスト">
    <path d="M8 22 Q48 14 88 22 L86 30 Q48 23 10 30 Z" fill="var(--shu)" />
    <rect x="16" y="36" width="64" height="5" fill="var(--shu)" />
    <rect x="24" y="30" width="7" height="56" fill="var(--shu)" transform="rotate(1.5 27 58)" />
    <rect x="65" y="30" width="7" height="56" fill="var(--shu)" transform="rotate(-1.5 68 58)" />
    <rect x="44" y="22" width="8" height="14" fill="var(--shu)" />
    <ellipse cx="48" cy="88" rx="36" ry="2.5" fill="var(--line)" />
  </svg>
)}

{name === 'ship' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="南蛮船のイラスト">
    <path d="M14 62 Q48 70 82 62 L74 78 Q48 84 22 78 Z" fill="var(--sumi)" />
    <rect x="30" y="24" width="3" height="38" fill="var(--sumi)" />
    <rect x="58" y="16" width="3" height="46" fill="var(--sumi)" />
    <path d="M33 26 Q46 32 33 44 Z" fill="var(--washi-deep)" stroke="var(--sumi)" stroke-width="1.5" />
    <path d="M61 18 Q78 28 61 44 Z" fill="var(--washi-deep)" stroke="var(--sumi)" stroke-width="1.5" />
    <path d="M61 18 L61 44 L44 44 Q52 30 61 18 Z" fill="var(--shu)" opacity="0.9" />
    <path d="M10 70 Q20 66 30 70 T50 70 T70 70 T90 70" stroke="var(--kincha)" stroke-width="2" fill="none" />
  </svg>
)}

{name === 'sekibutsu' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="磨崖仏のイラスト">
    <path d="M12 88 L12 30 Q30 8 48 10 Q70 8 84 30 L84 88 Z" fill="var(--washi-deep)" stroke="var(--line)" stroke-width="2" />
    <circle cx="48" cy="38" r="12" fill="var(--sumi)" />
    <circle cx="48" cy="24" r="4" fill="var(--sumi)" />
    <path d="M30 74 Q34 52 48 52 Q62 52 66 74 Z" fill="var(--sumi)" />
    <path d="M40 62 Q48 66 56 62" stroke="var(--washi)" stroke-width="1.5" fill="none" />
    <ellipse cx="48" cy="84" rx="26" ry="3" fill="var(--line)" />
  </svg>
)}

{name === 'castle' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="岡城の石垣と月のイラスト">
    <circle cx="70" cy="24" r="12" fill="var(--kincha)" opacity="0.85" />
    <path d="M14 88 L22 52 L74 52 L82 88 Z" fill="var(--sumi)" />
    <path d="M24 62 L72 62 M20 72 L76 72 M17 81 L79 81" stroke="var(--washi)" stroke-width="1.5" opacity="0.5" />
    <path d="M28 52 L34 40 L62 40 L68 52 Z" fill="var(--sumi)" opacity="0.7" />
    <path d="M6 90 Q48 86 90 90" stroke="var(--line)" stroke-width="2" fill="none" />
  </svg>
)}

{name === 'yufudake' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="由布岳と金鱗湖のイラスト">
    <path d="M12 62 L36 26 Q40 21 44 27 L48 33 L52 26 Q56 20 60 26 L84 62 Z" fill="var(--sumi)" opacity="0.45" />
    <path d="M40 32 L44 38 L48 33 L52 39 L56 32 L58 36 L48 44 L38 36 Z" fill="var(--washi)" opacity="0.7" />
    <circle cx="76" cy="18" r="6" fill="var(--kincha)" opacity="0.75" />
    <ellipse cx="48" cy="74" rx="30" ry="9" fill="var(--shu)" opacity="0.25" />
    <path d="M28 74 Q38 70 48 74 T68 74" stroke="var(--shu)" stroke-width="2.5" fill="none" stroke-linecap="round" />
    <path d="M56 66 L56 74 M52 68 L60 68" stroke="var(--sumi)" stroke-width="2" stroke-linecap="round" />
  </svg>
)}

{name === 'mizushiro' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="水城（中津城）のイラスト">
    <path d="M34 62 L38 50 L58 50 L62 62 Z" fill="var(--sumi)" opacity="0.85" />
    <rect x="40" y="34" width="16" height="16" fill="var(--washi-deep)" stroke="var(--sumi)" stroke-width="2" />
    <path d="M34 34 L48 24 L62 34 Z" fill="var(--sumi)" />
    <rect x="42" y="20" width="12" height="6" fill="var(--washi-deep)" stroke="var(--sumi)" stroke-width="1.6" />
    <path d="M38 20 L48 13 L58 20 Z" fill="var(--sumi)" />
    <path d="M46 40 L50 40 L50 46 L46 46 Z" fill="var(--sumi)" />
    <path d="M14 70 Q24 64 34 70 T54 70 T74 70 T88 70" stroke="var(--shu)" stroke-width="3" fill="none" stroke-linecap="round" />
    <path d="M20 80 Q30 74 40 80 T60 80 T80 80" stroke="var(--kincha)" stroke-width="2.5" fill="none" stroke-linecap="round" opacity="0.7" />
  </svg>
)}

{name === 'saka' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="石畳の坂（杵築）のイラスト">
    <path d="M10 26 L28 26 L28 38 L40 38 L40 52 L48 52 L48 80 L10 80 Z" fill="var(--washi-deep)" stroke="var(--sumi)" stroke-width="2.5" stroke-linejoin="round" />
    <path d="M86 26 L68 26 L68 38 L56 38 L56 52 L48 52 L48 80 L86 80 Z" fill="var(--washi-deep)" stroke="var(--sumi)" stroke-width="2.5" stroke-linejoin="round" />
    <path d="M14 32 L24 32 M32 44 L38 44 M62 32 L80 32 M58 44 L64 44" stroke="var(--line)" stroke-width="2" />
    <rect x="15" y="14" width="8" height="12" rx="1" fill="var(--shu)" />
    <rect x="73" y="14" width="8" height="12" rx="1" fill="var(--shu)" />
    <ellipse cx="48" cy="86" rx="34" ry="2.5" fill="var(--line)" />
  </svg>
)}

{name === 'yamajiro' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="山城と海（佐伯）のイラスト">
    <path d="M12 70 L48 26 L84 70 Z" fill="var(--sumi)" opacity="0.25" />
    <path d="M38 34 L42 22 L54 22 L58 34 Z" fill="var(--sumi)" />
    <path d="M42 27 L54 27" stroke="var(--washi)" stroke-width="1.5" opacity="0.6" />
    <circle cx="74" cy="18" r="6" fill="var(--kincha)" opacity="0.75" />
    <path d="M10 80 Q20 74 30 80 T50 80 T70 80 T88 80" stroke="var(--shu)" stroke-width="3" fill="none" stroke-linecap="round" />
    <path d="M56 44 Q60 40 64 44 M64 52 Q68 48 72 52" stroke="var(--washi)" stroke-width="2" opacity="0.8" fill="none" />
  </svg>
)}

{name === 'taimatsu' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="松明と炎のイラスト">
    <path d="M48 12 Q60 26 54 36 Q64 34 62 22 Q74 34 66 48 Q58 60 48 56 Q38 60 30 48 Q22 34 34 22 Q32 34 42 36 Q36 26 48 12 Z" fill="var(--shu)" />
    <path d="M48 28 Q54 36 48 44 Q42 36 48 28 Z" fill="var(--kincha)" />
    <rect x="44" y="56" width="8" height="28" rx="2" fill="var(--sumi)" />
    <path d="M40 58 L56 58" stroke="var(--kincha)" stroke-width="3" stroke-linecap="round" />
    <ellipse cx="48" cy="88" rx="28" ry="2.5" fill="var(--line)" />
  </svg>
)}

{name === 'cross' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="十字架と波のイラスト">
    <rect x="44" y="14" width="8" height="56" rx="2" fill="var(--shu)" />
    <rect x="28" y="30" width="40" height="8" rx="2" fill="var(--shu)" />
    <path d="M24 78 Q32 72 40 78 T56 78 T72 78" stroke="var(--kincha)" stroke-width="2.5" fill="none" />
    <circle cx="70" cy="22" r="7" fill="var(--kincha)" opacity="0.7" />
    <ellipse cx="48" cy="86" rx="30" ry="2.5" fill="var(--line)" />
  </svg>
)}

{name === 'school' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="私塾（学びの家）のイラスト">
    <path d="M14 44 L48 20 L82 44 Z" fill="var(--sumi)" />
    <rect x="22" y="44" width="52" height="34" fill="var(--washi-deep)" stroke="var(--sumi)" stroke-width="2" />
    <rect x="42" y="56" width="12" height="22" fill="var(--sumi)" />
    <path d="M28 52 L38 52 M58 52 L68 52" stroke="var(--sumi)" stroke-width="2" />
    <path d="M30 30 Q34 24 40 26 M26 12 L30 20 M36 8 L37 16" stroke="var(--shu)" stroke-width="2.5" stroke-linecap="round" fill="none" />
    <ellipse cx="48" cy="84" rx="34" ry="2.5" fill="var(--line)" />
  </svg>
)}

{name === 'stadium' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="スタジアムのイラスト">
    <path d="M14 58 Q48 22 82 58" stroke="var(--sumi)" stroke-width="4" fill="none" stroke-linecap="round" />
    <path d="M20 58 Q48 30 76 58 L76 70 Q48 60 20 70 Z" fill="var(--washi-deep)" stroke="var(--sumi)" stroke-width="2" />
    <ellipse cx="48" cy="68" rx="30" ry="8" fill="var(--shu)" opacity="0.85" />
    <ellipse cx="48" cy="66" rx="18" ry="4.5" fill="var(--washi)" />
    <circle cx="48" cy="40" r="5" fill="var(--kincha)" />
    <ellipse cx="48" cy="86" rx="36" ry="2.5" fill="var(--line)" />
  </svg>
)}

{name === 'yukemuri' && (
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="温泉と湯けむりのイラスト">
    <path d="M20 66 Q48 58 76 66 L72 82 Q48 88 24 82 Z" fill="var(--shu)" />
    <path d="M34 54 Q28 44 34 36 Q40 28 34 18" stroke="var(--sumi-usui)" stroke-width="3" fill="none" stroke-linecap="round" />
    <path d="M48 52 Q42 42 48 34 Q54 26 48 14" stroke="var(--sumi-usui)" stroke-width="3" fill="none" stroke-linecap="round" />
    <path d="M62 54 Q56 44 62 36 Q68 28 62 18" stroke="var(--sumi-usui)" stroke-width="3" fill="none" stroke-linecap="round" />
    <ellipse cx="48" cy="88" rx="34" ry="2.5" fill="var(--line)" />
  </svg>
)}
