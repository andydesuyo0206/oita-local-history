---
// 大分県デフォルメ地図：地域を選んで各記事へ飛べるナビゲーション
// ※正確な県境ではなく、位置関係をデフォルメしたイラスト地図です
// リンクはSVG内<a>ではなくHTMLオーバーレイ（クリック挙動が全ブラウザで確実なため）
const VIEW_W = 560;
const VIEW_H = 440;
const regions = [
  { id: 'nakatsu', label: '中津', x: 145, y: 85, href: '/area/nakatsu/' },
  { id: 'usa-kunisaki', label: '宇佐・国東', x: 340, y: 88, href: '/area/usa-kunisaki/' },
  { id: 'kitsuki', label: '杵築', x: 390, y: 140, href: '/area/kitsuki/' },
  { id: 'hita', label: '日田', x: 125, y: 235, href: '/area/hita/' },
  { id: 'beppu', label: '別府', x: 322, y: 200, href: '/area/beppu/' },
  { id: 'yufuin', label: '由布院', x: 272, y: 222, href: '/area/yufuin/' },
  { id: 'funai', label: '府内', x: 400, y: 242, href: '/area/funai/' },
  { id: 'usuki', label: '臼杵', x: 422, y: 300, href: '/area/usuki/' },
  { id: 'taketa', label: '竹田', x: 235, y: 330, href: '/area/taketa/' },
  { id: 'saiki', label: '佐伯', x: 398, y: 372, href: '/area/saiki/' },
] as const;
---

<div class="map-wrap">
  <div class="map-stage">
    <svg
      viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="大分県のデフォルメ地図"
    >
      <!-- 海（全面を薄く塗り、県土を上に重ねる） -->
      <rect x="0" y="0" width="560" height="440" fill="var(--shu)" opacity="0.05" />

      <!-- 県土（実形状ベースのデフォルメ：北岸→丸い国東半島→別府湾の湾入→
           佐賀関の細い岬→南部リアス海岸→内陸県境の順に描画） -->
      <path
        d="M105 95
           Q160 72 225 70
           Q250 66 268 72
           C290 30 360 12 415 40
           C452 62 462 105 442 138
           Q430 155 410 162
           Q368 172 346 190
           Q352 212 388 214
           L505 194
           Q512 199 505 204
           L448 226
           Q454 252 444 264
           Q462 274 456 294
           Q443 307 453 322
           Q466 340 451 357
           Q436 364 443 380
           Q449 402 426 414
           Q360 427 300 417
           Q230 404 185 400
           Q130 394 118 352
           Q95 302 92 252
           Q88 192 98 142
           Q100 112 105 95 Z"
        fill="var(--washi-deep)"
        stroke="var(--kincha)"
        stroke-width="2.5"
        stroke-linejoin="round"
      />

      <!-- 波の装飾（周防灘・別府湾・豊後水道） -->
      <path d="M300 38 Q312 32 324 38 T348 38" stroke="var(--kincha)" stroke-width="2" opacity="0.5" />
      <path d="M488 130 Q500 124 512 130 T536 130" stroke="var(--kincha)" stroke-width="2" opacity="0.5" />
      <path d="M492 320 Q504 314 516 320 T540 320" stroke="var(--kincha)" stroke-width="2" opacity="0.5" />

      <!-- 山の装飾（由布岳の双耳峰とくじゅう連山のイメージ） -->
      <path d="M268 195 L282 173 L292 187 L300 175 L312 195 Z" fill="var(--sumi)" opacity="0.15" />
      <path d="M170 300 L190 272 L210 300 Z M200 304 L216 282 L232 304 Z" fill="var(--sumi)" opacity="0.12" />
    </svg>

    <!-- 地域リンク（HTMLオーバーレイ：% 配置でSVGと連動して拡縮） -->
    {
      regions.map((r) => (
        <a
          href={r.href}
          class="region-hit"
          style={`left:${(r.x / VIEW_W) * 100}%; top:${(r.y / VIEW_H) * 100}%`}
          aria-label={`${r.label}の記事を読む`}
        >
          <span class="region-circle" aria-hidden="true" />
          <span class="region-label">{r.label}</span>
        </a>
      ))
    }
  </div>
  <p class="map-note">※ 位置関係をデフォルメしたイラスト地図です。地域を選ぶと記事へ移動します。</p>
</div>

<style>
  .map-wrap {
    max-width: 560px;
    margin: 0 auto;
  }
  .map-stage {
    position: relative;
  }
  .map-stage svg {
    display: block;
    width: 100%;
    height: auto;
  }
  .region-hit {
    position: absolute;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    text-decoration: none;
    /* タップ領域の確保（44px以上） */
    min-width: 48px;
    min-height: 48px;
    justify-content: center;
  }
  .region-circle {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    /* 親opacityだと中心ドットまで薄くなるため rgba で塗る（--shu #b13a2f 相当） */
    background: rgba(177, 58, 47, 0.16);
    transition: background 0.25s, transform 0.25s;
    position: relative;
  }
  /* 中心の点 */
  .region-circle::after {
    content: '';
    position: absolute;
    inset: 0;
    margin: auto;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--shu);
  }
  .region-hit:hover .region-circle,
  .region-hit:focus .region-circle {
    background: rgba(177, 58, 47, 0.34);
    transform: scale(1.15);
  }
  .region-label {
    font-family: var(--font-mincho);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--sumi);
    white-space: nowrap;
    text-shadow: 0 0 6px var(--washi), 0 0 3px var(--washi);
  }
  .region-hit:hover .region-label,
  .region-hit:focus .region-label {
    color: var(--shu);
  }
  .map-note {
    text-align: center;
    font-size: 0.78rem;
    color: var(--sumi-usui);
    margin-top: 0.6rem;
  }
  @media (max-width: 600px) {
    .region-label {
      font-size: 0.78rem;
    }
    .region-circle {
      width: 28px;
      height: 28px;
    }
  }
</style>
