---
// 共通レイアウト：ヘッダー・フッター・和風テーマ
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = '大分県の郷土史を、イラストとともにたどる読み物サイト' } = Astro.props;

// OGP用の絶対URL（astro.config の site 設定から生成。未設定時は相対パス）
const ogImage = Astro.site ? new URL('ogp.png', Astro.site).href : '/ogp.png';
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="8cukl3bEculrD5uketLON0CczakQ6ncTphp46ltbykg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#b13a2f" />
    {canonical && <link rel="canonical" href={canonical} />}
    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="豊の国・大分 郷土史" />
    <meta property="og:locale" content="ja_JP" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner container">
        <a href="/" class="site-title">
          <span class="title-mark">豊</span>
          <span class="title-text">豊の国・大分 郷土史</span>
        </a>
        <nav class="site-nav">
          <a href="/#nenpyo">年表</a>
          <a href="/#chiiki">地域から</a>
          <a href="/#tema">テーマで</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p class="footer-note">
          本サイトの記述は、自治体・観光協会などの公的な情報源をもとにしています。各記事末尾の「出典」をご参照ください。
        </p>
        <p class="footer-copy">豊の国・大分 郷土史</p>
      </div>
    </footer>

    <script>
      // スクロール連動フェードイン：data-animate 要素が画面に入ったら表示
      // フェイルセーフ設計：非表示化はJS実行時のみ（html.anim）。
      // IntersectionObserver が発火しない環境でも一定時間後に必ず表示する。
      const targets = document.querySelectorAll<HTMLElement>('[data-animate]');
      if (targets.length > 0 && 'IntersectionObserver' in window) {
        document.documentElement.classList.add('anim');
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15 }
        );
        targets.forEach((el) => observer.observe(el));
        // 保険：2秒経っても未表示の要素は強制表示（IO不発火・計測ずれ対策）
        setTimeout(() => {
          targets.forEach((el) => el.classList.add('is-visible'));
        }, 2000);
      }
    </script>
  </body>
</html>

<style>
  .site-header {
    border-bottom: 1px solid var(--line);
    background: rgba(246, 241, 231, 0.92);
    position: sticky;
    top: 0;
    backdrop-filter: blur(6px);
    z-index: 10;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.8rem;
    padding-bottom: 0.8rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .site-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--sumi);
  }
  .title-mark {
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    background: var(--shu);
    color: var(--washi);
    border-radius: 3px;
    font-size: 1.1rem;
  }
  .title-text {
    font-size: 1.05rem;
    letter-spacing: 0.12em;
  }
  .site-nav {
    display: flex;
    gap: 1.4rem;
  }
  .site-nav a {
    color: var(--sumi);
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
  }
  .site-nav a:hover {
    color: var(--shu);
  }
  /* スマホ：ヘッダーを詰めてナビをタップしやすく */
  @media (max-width: 600px) {
    .header-inner {
      justify-content: center;
      row-gap: 0.2rem;
    }
    .title-text {
      font-size: 0.95rem;
    }
    .site-nav {
      gap: 1rem;
    }
    .site-nav a {
      padding: 0.4rem 0.2rem; /* タップ領域の確保 */
    }
  }
  .site-footer {
    border-top: 1px solid var(--line);
    margin-top: 5rem;
    padding: 2.5rem 0 3rem;
    background: var(--washi-deep);
  }
  .footer-note {
    font-size: 0.82rem;
    color: var(--sumi-usui);
    max-width: 40em;
  }
  .footer-copy {
    margin-top: 1.2rem;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    color: var(--sumi-usui);
  }
</style>
